<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <AssemblyName>LimbusRuntimeUIInspector</AssemblyName>
    <RootNamespace>LimbusRuntimeUIInspector</RootNamespace>
    <GameDir>C:\Program Files (x86)\Steam\steamapps\common\Limbus Company</GameDir>
    <BepInExDir>$(GameDir)\BepInEx</BepInExDir>
    <CoreDir>$(BepInExDir)\core</CoreDir>
    <InteropDir>$(BepInExDir)\interop</InteropDir>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\Shared\*.cs" Link="Shared\%(Filename)%(Extension)" />
    <Compile Include="ApiContracts.cs" />
    <Compile Include="CanvasRootRegistry.cs" />
    <Compile Include="ContentTypes.cs" />
    <Compile Include="ElementContracts.cs" />
    <Compile Include="InspectorJobs.cs" />
    <Compile Include="InspectorHost.cs" />
    <Compile Include="InspectorPage.cs" />
    <Compile Include="InspectorServer.cs" />
    <Compile Include="JobContracts.cs" />
    <Compile Include="JsonOptions.cs" />
    <Compile Include="Plugin.cs" />
    <Compile Include="RectTransformCapture.cs" />
    <Compile Include="ScanContracts.cs" />
    <Compile Include="UnityDetours.cs" />
    <Compile Include="UnityInteropNames.cs" />
    <Compile Include="UnityUiRuntime.cs" />
    <Compile Include="UnityUiRuntime.Edit.cs" />
    <Compile Include="UnityUiRuntime.Read.cs" />
    <Compile Include="UnityUiRuntime.Scan.cs" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="BepInEx.Core">
      <HintPath>$(CoreDir)\BepInEx.Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="BepInEx.Unity.IL2CPP">
      <HintPath>$(CoreDir)\BepInEx.Unity.IL2CPP.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Il2CppInterop.Runtime">
      <HintPath>$(CoreDir)\Il2CppInterop.Runtime.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="MonoMod.RuntimeDetour">
      <HintPath>$(CoreDir)\MonoMod.RuntimeDetour.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <Target Name="DeployMod" AfterTargets="Build" Condition="'$(SkipDeploy)' != 'true'">
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(BepInExDir)\plugins" />
    <Message Importance="high" Text="Deployed to $(BepInExDir)\plugins\$(AssemblyName).dll" />
  </Target>
</Project>
